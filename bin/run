#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ROOT_GEMFILE="$ROOT_DIR/Gemfile"
RUN_GROUPS=(lecciones practicas socket io experiments basics collections oop cli networking)

cd "$ROOT_DIR"

print_help() {
  cat <<'EOF'
Uso:
  bin/run --help
  bin/run list
  bin/run <grupo> <archivo-sin-ext> [args...]
  bin/run auto <grupo> <archivo-sin-ext> [args...]
  bin/run local <grupo> <archivo-sin-ext> [args...]
  bin/run docker <grupo> <archivo-sin-ext> [args...]

Grupos disponibles:
  - lecciones
  - practicas
  - socket
  - io
  - experiments
  - basics
  - collections
  - oop
  - cli
  - networking

Ejemplos:
  bin/run list
  bin/run lecciones 00
  bin/run auto practicas mind-reader
  bin/run local socket 08
  bin/run local io file-reading
  bin/run local experiments tk-gui
  bin/run local basics strings
  bin/run local collections hashes
  bin/run local oop methods-classes-and-inheritance
  bin/run local cli roller
  bin/run local networking tcp-server-basic

Notas:
  - 'auto' prioriza Docker Compose si está disponible y, si no, usa Ruby local.
  - También podés omitir el modo: 'bin/run lecciones 00' funciona como alias de 'auto'.
EOF
}

group_exists() {
  local requested="$1"

  for group in "${RUN_GROUPS[@]}"; do
    if [[ "$group" == "$requested" ]]; then
      return 0
    fi
  done

  return 1
}

resolve_path() {
  local group="$1"
  local file_name="$2"
  local normalized="${file_name%.rb}"
  local candidate="examples/${group}/${normalized}.rb"

  if [[ -f "$candidate" ]]; then
    printf '%s\n' "$candidate"
    return 0
  fi

  if [[ "$group" == "lecciones" ]]; then
    case "$normalized" in
      00)
        printf '%s\n' "examples/basics/types-and-booleans.rb"
        return 0
        ;;
      01)
        printf '%s\n' "examples/basics/strings.rb"
        return 0
        ;;
      02)
        printf '%s\n' "examples/collections/arrays-and-ranges.rb"
        return 0
        ;;
      03)
        printf '%s\n' "examples/collections/hashes.rb"
        return 0
        ;;
      04)
        printf '%s\n' "examples/oop/methods-classes-and-inheritance.rb"
        return 0
        ;;
      05)
        printf '%s\n' "examples/oop/scope-and-metaprogramming.rb"
        return 0
        ;;
      06)
        printf '%s\n' "examples/oop/singleton-methods-and-procs.rb"
        return 0
        ;;
      09)
        printf '%s\n' "examples/io/file-reading.rb"
        return 0
        ;;
      10)
        printf '%s\n' "examples/experiments/tk-gui.rb"
        return 0
        ;;
      11)
        printf '%s\n' "examples/io/user-input.rb"
        return 0
        ;;
      07)
        printf '%s\n' "examples/basics/control-flow.rb"
        return 0
        ;;
      08)
        printf '%s\n' "examples/collections/iterators-and-enumerators.rb"
        return 0
        ;;
      12)
        printf '%s\n' "examples/basics/percent-notation-and-bang-methods.rb"
        return 0
        ;;
    esac
  fi

  if [[ "$group" == "practicas" ]]; then
    case "$normalized" in
      mind-reader)
        printf '%s\n' "examples/cli/mind-reader.rb"
        return 0
        ;;
      roller)
        printf '%s\n' "examples/cli/roller.rb"
        return 0
        ;;
      speed)
        printf '%s\n' "examples/basics/speed-rules.rb"
        return 0
        ;;
      simple_stats)
        printf '%s\n' "examples/basics/simple-stats.rb"
        return 0
        ;;
      math-method)
        printf '%s\n' "examples/oop/math-with-blocks.rb"
        return 0
        ;;
      get-data)
        printf '%s\n' "examples/experiments/get-data.rb"
        return 0
        ;;
    esac
  fi

  if [[ "$group" == "socket" ]]; then
    case "$normalized" in
      08)
        printf '%s\n' "examples/networking/tcp-server-basic.rb"
        return 0
        ;;
      09)
        printf '%s\n' "examples/networking/tcp-client-basic.rb"
        return 0
        ;;
      10)
        printf '%s\n' "examples/experiments/tcp-broadcast-attempt.rb"
        return 0
        ;;
      11)
        printf '%s\n' "examples/networking/tcp-client-interactive.rb"
        return 0
        ;;
    esac
  fi

  return 1
}

docker_available() {
  command -v docker >/dev/null 2>&1 && docker compose version >/dev/null 2>&1 && docker info >/dev/null 2>&1
}

ruby_available() {
  command -v ruby >/dev/null 2>&1
}

bundler_available() {
  command -v bundle >/dev/null 2>&1
}

print_groups() {
  printf 'Grupos disponibles:\n'
  for group in "${RUN_GROUPS[@]}"; do
    printf '  - %s\n' "$group"
  done
}

list_examples() {
  local group file name

  print_groups
  printf '\nEjemplos por grupo:\n'

  for group in "${RUN_GROUPS[@]}"; do
    printf '\n[%s]\n' "$group"

    for file in "examples/${group}"/*.rb; do
      [[ -e "$file" ]] || continue
      name="${file##*/}"
      name="${name%.rb}"
      printf '  - %s\n' "$name"
    done
  done
}

fail() {
  printf '%s\n' "$1" >&2
  exit "${2:-1}"
}

run_local() {
  local path="$1"
  shift

  ruby_available || fail "Ruby local no está disponible en PATH." 4

  if [[ -f "$ROOT_GEMFILE" ]]; then
    bundler_available || fail "Hay Gemfile raíz, pero bundle no está disponible en PATH." 6
    exec bundle exec ruby "$path" "$@"
  fi

  exec ruby "$path" "$@"
}

run_docker() {
  local path="$1"
  shift

  docker_available || fail "Docker Compose no está disponible para ejecutar este ejemplo." 5

  if [[ -f "$ROOT_GEMFILE" ]]; then
    exec docker compose run --rm ruby bundle exec ruby "$path" "$@"
  fi

  exec docker compose run --rm ruby ruby "$path" "$@"
}

MODE="auto"

case "${1:-}" in
  ""|-h|--help|help)
    print_help
    exit 0
    ;;
  list)
    list_examples
    exit 0
    ;;
  auto|local|docker)
    MODE="$1"
    shift
    ;;
esac

[[ $# -ge 2 ]] || fail "Argumentos insuficientes. Usá 'bin/run --help' para ver la ayuda." 1

GROUP="$1"
FILE_NAME="$2"
shift 2

group_exists "$GROUP" || fail "Grupo inválido: $GROUP. Usá 'bin/run list' para ver opciones disponibles." 2

PATH_TO_FILE="$(resolve_path "$GROUP" "$FILE_NAME")" || fail "No existe un ejemplo para grupo=$GROUP archivo=${FILE_NAME%.rb}. Usá 'bin/run list' para ver ejemplos disponibles." 3

case "$MODE" in
  auto)
    if docker_available; then
      run_docker "$PATH_TO_FILE" "$@"
    else
      run_local "$PATH_TO_FILE" "$@"
    fi
    ;;
  local)
    run_local "$PATH_TO_FILE" "$@"
    ;;
  docker)
    run_docker "$PATH_TO_FILE" "$@"
    ;;
esac
